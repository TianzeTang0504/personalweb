# Gemini API Key (From Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# OpenAI API Key (For writer.html AI coaching features)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Optional model override for writing coaching
OPENAI_WRITING_MODEL=gpt-5.5

# Gmail Credentials (Use App Passwords, NOT your real password)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_16_digit_app_password_here
